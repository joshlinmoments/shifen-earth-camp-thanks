rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 感謝照片：任何人可讀取；上傳限圖片、單檔 8MB 內。
    match /photos/{photo} {
      allow read: if true;
      allow write: if
        request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
